<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no, viewport-fit=cover"/>
<title>さくら · Sakura Dining</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Noto+Serif+JP:wght@200;300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
<style>
:root {
  --ink:#080604; --ink2:#12100E; --paper:#F0E8D5;
  --beni:#7A2E1E; --beni2:#A03D28; --beni3:#C4513A;
  --yama:#B8973A; --yama2:#D4AE52;
  --ff-jp:'Noto Serif JP',serif;
  --ff-en:'Cormorant Garamond',serif;
  --ff-ui:'DM Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{height:100%;overflow:hidden}
body{
  width:100vw;height:100%;overflow:hidden;
  font-family:var(--ff-ui);background:var(--ink);color:var(--paper);
  -webkit-tap-highlight-color:transparent;
  /* NO touch-action:none on body — let model-viewer handle its own touches */
}
body::before{
  content:'';position:fixed;inset:0;z-index:9998;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.04'/%3E%3C/svg%3E");
  opacity:0.5;mix-blend-mode:overlay;
}

/* SPLASH */
#splash{position:fixed;inset:0;z-index:9999;background:#080604;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 1s cubic-bezier(0.4,0,0.2,1)}
#splash.out{opacity:0;pointer-events:none}
.splash-mon{width:90px;height:90px;border-radius:50%;border:1px solid rgba(122,46,30,0.4);display:flex;align-items:center;justify-content:center;margin-bottom:28px;position:relative;animation:monGlow 3s ease-in-out infinite}
@keyframes monGlow{0%,100%{box-shadow:0 0 0 0 rgba(122,46,30,0)}50%{box-shadow:0 0 40px 8px rgba(122,46,30,0.15)}}
.splash-mon::before{content:'';position:absolute;inset:-12px;border-radius:50%;border:1px solid rgba(122,46,30,0.15)}
.s-title{font-family:var(--ff-en);font-size:52px;font-weight:300;letter-spacing:0.14em;animation:fadeUp 1s ease 0.3s both}
.s-jp{font-family:var(--ff-jp);font-size:11px;font-weight:200;letter-spacing:0.45em;color:rgba(122,46,30,0.7);margin-top:10px;animation:fadeUp 1s ease 0.5s both}
.s-bar{position:absolute;bottom:48px;left:50%;transform:translateX(-50%);width:120px;animation:fadeUp 0.6s ease 1s both}
.s-bar-track{height:1px;background:rgba(240,232,213,0.08)}
.s-bar-fill{height:1px;background:linear-gradient(90deg,var(--beni),var(--yama));width:0;animation:barFill 3.5s linear 0.8s forwards}
@keyframes barFill{to{width:100%}}
.s-bar-txt{text-align:center;font-size:8px;letter-spacing:0.3em;color:rgba(240,232,213,0.18);margin-top:10px;text-transform:uppercase}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* LAYOUT */
#app{position:fixed;inset:0;display:flex;overflow:hidden}

/* ─── SIDE SLIDER PANEL ───
   touch-action:none ONLY here so it captures pointer events exclusively */
#sliderPanel{
  position:relative;z-index:100;
  width:42px;flex-shrink:0;
  display:flex;flex-direction:column;align-items:center;
  background:rgba(6,4,2,0.9);
  border-right:1px solid rgba(240,232,213,0.05);
  padding:calc(68px + env(safe-area-inset-top)) 0 calc(18px + env(safe-area-inset-bottom));
  /* Capture all touch input within this panel — model-viewer is NOT inside here */
  touch-action:none;
}
.sp-label{font-family:var(--ff-jp);font-size:7px;font-weight:200;color:rgba(240,232,213,0.18);letter-spacing:0.2em;writing-mode:vertical-rl;margin:6px 0}

#sliderTrackWrap{
  flex:1;width:100%;position:relative;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
}
#sliderRail{position:absolute;left:50%;transform:translateX(-50%);width:2px;top:0;bottom:0;background:rgba(240,232,213,0.07);border-radius:1px}
#sliderFill{position:absolute;left:50%;transform:translateX(-50%);width:2px;top:0;height:0;background:linear-gradient(to bottom,var(--beni),var(--beni2));border-radius:1px;transition:height 0.03s linear}
#sliderThumb{
  position:absolute;left:50%;transform:translate(-50%,0);top:0;
  width:30px;height:30px;border-radius:50%;
  background:radial-gradient(circle at 38% 32%,var(--beni3),var(--beni));
  border:2px solid rgba(240,232,213,0.18);
  box-shadow:0 0 16px rgba(160,61,40,0.55),0 2px 6px rgba(0,0,0,0.5);
  cursor:grab;display:flex;align-items:center;justify-content:center;
  transition:box-shadow 0.15s;
  z-index:2;
}
#sliderThumb.active{cursor:grabbing;box-shadow:0 0 24px rgba(160,61,40,0.8),0 4px 10px rgba(0,0,0,0.6)}
#sliderThumb::after{content:'';width:5px;height:5px;border-radius:50%;background:rgba(240,232,213,0.45)}
#sliderTooltip{
  position:absolute;right:48px;
  background:rgba(8,6,4,0.88);border:1px solid rgba(240,232,213,0.1);border-radius:5px;
  padding:5px 10px;white-space:nowrap;pointer-events:none;
  font-family:var(--ff-en);font-size:13px;color:var(--yama2);letter-spacing:0.05em;
  opacity:0;transition:opacity 0.2s;z-index:10;
}
#sliderTooltip.show{opacity:1}

/* SCROLL AREA — touch-action:pan-y allows natural vertical scroll feel
   but model-viewer children will override with their own touch-action */
#scrollArea{
  flex:1;overflow:hidden;position:relative;
  touch-action:pan-y;
}
#cardTrack{position:absolute;top:0;left:0;right:0;will-change:transform}

/* HUD */
#hud{
  position:fixed;top:0;left:42px;right:0;z-index:50;
  padding:calc(14px + env(safe-area-inset-top)) 18px 14px;
  background:linear-gradient(to bottom,rgba(8,6,4,0.85) 0%,transparent 100%);
  display:flex;align-items:center;justify-content:space-between;pointer-events:none;
}
.hud-brand{font-family:var(--ff-en);font-size:22px;font-weight:400;letter-spacing:0.12em;pointer-events:all}
.hud-brand span{font-family:var(--ff-jp);font-size:10px;font-weight:200;letter-spacing:0.3em;color:rgba(240,232,213,0.35);display:block}
.hud-right{display:flex;align-items:center;gap:10px;pointer-events:all}
.hud-table{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--yama2);border:1px solid rgba(184,151,58,0.25);border-radius:3px;padding:5px 10px}
.hud-cart-btn{width:38px;height:38px;border-radius:50%;background:rgba(240,232,213,0.07);border:1px solid rgba(240,232,213,0.1);display:flex;align-items:center;justify-content:center;font-size:17px;cursor:pointer;position:relative;transition:all 0.2s}
.hud-cart-btn:active{transform:scale(0.9)}
.hud-cart-count{position:absolute;top:-3px;right:-3px;width:16px;height:16px;border-radius:50%;background:var(--beni2);border:1.5px solid var(--ink);font-size:8px;font-weight:600;color:var(--paper);display:none;align-items:center;justify-content:center}
.hud-cart-count.show{display:flex}

/* DISH CARD */
.dish-card{width:100%;position:absolute;left:0;right:0;overflow:hidden;display:flex;flex-direction:column}
.dish-bg{position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse 80% 60% at 20% 30%,rgba(122,46,30,0.22) 0%,transparent 60%),radial-gradient(ellipse 60% 50% at 80% 70%,rgba(184,151,58,0.1) 0%,transparent 50%),var(--ink2)}
.dish-viewer{position:relative;z-index:5;flex:1;overflow:hidden;min-height:0}

/* model-viewer: let it own ALL touch events within its bounds */
model-viewer{
  width:100%;height:100%;background:transparent;--poster-color:transparent;
  /* model-viewer sets touch-action internally; don't override it */
}

.viewer-no-model{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px}
.viewer-no-emoji{font-size:88px;animation:floatEmoji 4s ease-in-out infinite}
@keyframes floatEmoji{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-10px) rotate(3deg)}}
.viewer-no-txt{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(240,232,213,0.2)}
.viewer-corner{position:absolute;z-index:10;pointer-events:none;width:18px;height:18px}
.viewer-corner.tl{top:14px;left:14px;border-top:1px solid rgba(122,46,30,0.5);border-left:1px solid rgba(122,46,30,0.5)}
.viewer-corner.tr{top:14px;right:14px;border-top:1px solid rgba(122,46,30,0.5);border-right:1px solid rgba(122,46,30,0.5)}
.viewer-corner.bl{bottom:14px;left:14px;border-bottom:1px solid rgba(122,46,30,0.5);border-left:1px solid rgba(122,46,30,0.5)}
.viewer-corner.br{bottom:14px;right:14px;border-bottom:1px solid rgba(122,46,30,0.5);border-right:1px solid rgba(122,46,30,0.5)}
.viewer-badge{position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:10;display:flex;align-items:center;gap:6px;background:rgba(8,6,4,0.55);border:1px solid rgba(240,232,213,0.08);border-radius:30px;padding:5px 12px;pointer-events:none}
.vb-dot{width:5px;height:5px;border-radius:50%;background:var(--beni2);animation:blinkDot 2s ease infinite}
@keyframes blinkDot{0%,100%{opacity:1}50%{opacity:0.2}}
.vb-txt{font-size:8px;letter-spacing:0.22em;text-transform:uppercase;color:rgba(240,232,213,0.45)}
.sumi-line{position:relative;z-index:10;padding:0 22px;flex-shrink:0}
.sumi-line svg{display:block;width:100%;height:8px}
.dish-info{position:relative;z-index:10;padding:12px 18px 0;flex-shrink:0;background:linear-gradient(to top,rgba(8,6,4,0.95) 0%,rgba(8,6,4,0.6) 100%)}
.info-category{font-size:8px;letter-spacing:0.32em;text-transform:uppercase;color:var(--beni2);margin-bottom:4px;display:flex;align-items:center;gap:8px}
.info-category::before{content:'';width:18px;height:1px;background:linear-gradient(90deg,var(--beni),transparent)}
.info-names{display:flex;align-items:baseline;gap:12px;margin-bottom:4px}
.info-name-en{font-family:var(--ff-en);font-size:30px;font-weight:400;line-height:1;letter-spacing:0.02em}
.info-name-jp{font-family:var(--ff-jp);font-size:13px;font-weight:200;letter-spacing:0.1em;color:rgba(240,232,213,0.35)}
.info-desc{font-size:11px;font-weight:300;color:rgba(240,232,213,0.45);line-height:1.6;margin-bottom:10px;max-height:3.2em;overflow:hidden}
.info-meta{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.info-price{font-family:var(--ff-en);font-size:26px;font-weight:400;color:var(--yama2);letter-spacing:0.04em}
.info-pills{display:flex;gap:5px;flex-wrap:wrap}
.info-pill{font-size:8px;letter-spacing:0.12em;text-transform:uppercase;padding:3px 9px;border-radius:2px;font-weight:400}
.pill-veg{background:rgba(40,90,45,0.15);color:#8DC89A;border:1px solid rgba(40,90,45,0.3)}
.pill-chef{background:rgba(184,151,58,0.1);color:var(--yama2);border:1px solid rgba(184,151,58,0.2)}
.pill-new{background:rgba(27,42,74,0.2);color:#90CAF9;border:1px solid rgba(27,42,74,0.4)}
.dish-actions{position:relative;z-index:10;padding:0 18px calc(12px + env(safe-area-inset-bottom));display:flex;gap:10px;align-items:stretch;flex-shrink:0;background:rgba(8,6,4,0.95)}
.btn-add-cart{flex:1;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--beni3) 0%,var(--beni) 100%);border:none;border-radius:4px;padding:13px 12px;font-family:var(--ff-ui);font-size:12px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--paper);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 4px 28px rgba(122,46,30,0.45);transition:all 0.2s cubic-bezier(0.34,1.56,0.64,1)}
.btn-add-cart::before{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(240,232,213,0.2),transparent);animation:shimmer 2.4s ease-in-out infinite}
@keyframes shimmer{0%{left:-100%}60%,100%{left:140%}}
.btn-add-cart:active{transform:scale(0.97)}
.btn-add-cart.added-pulse{background:linear-gradient(135deg,#2a6e30,#1d5023);box-shadow:0 4px 28px rgba(40,110,48,0.5)}
.btn-add-cart-icon{font-size:20px;line-height:1}
.btn-add-cart-text{display:flex;flex-direction:column;align-items:flex-start;gap:1px}
.btn-add-cart-main{font-size:12px;font-weight:500}
.btn-add-cart-sub{font-size:8px;color:rgba(240,232,213,0.6);font-weight:300;letter-spacing:0.1em}
.btn-cart-counter{position:absolute;top:-1px;right:-1px;width:18px;height:18px;border-radius:50%;background:var(--yama);border:2px solid var(--ink);font-size:9px;font-weight:700;color:var(--ink);display:none;align-items:center;justify-content:center}
.btn-cart-counter.show{display:flex}
.btn-ar-float{width:50px;flex-shrink:0;background:rgba(240,232,213,0.06);border:1px solid rgba(240,232,213,0.12);border-radius:4px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1)}
.btn-ar-float:active{transform:scale(0.9);background:rgba(122,46,30,0.25)}
.btn-ar-float-icon{font-size:18px;line-height:1}
.btn-ar-float-txt{font-size:7px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(240,232,213,0.4)}
.btn-ar-float.no-model{opacity:0.35;cursor:default}
.model-loader{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);display:none;flex-direction:column;align-items:center;gap:10px;pointer-events:none}
.loader-ring{width:32px;height:32px;border:1.5px solid rgba(122,46,30,0.15);border-top-color:var(--beni2);border-radius:50%;animation:spin 0.7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-txt{font-size:8px;letter-spacing:0.24em;text-transform:uppercase;color:rgba(240,232,213,0.24)}

/* ORDER */
#screenOrder{position:fixed;inset:0;z-index:200;background:var(--ink2);display:none;flex-direction:column;transform:translateY(100%);transition:transform 0.5s cubic-bezier(0.22,1,0.36,1)}
#screenOrder.show{display:flex;transform:translateY(0)}
.order-header{padding:calc(18px + env(safe-area-inset-top)) 22px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(240,232,213,0.06);flex-shrink:0}
.order-header-title{font-family:var(--ff-en);font-size:26px;font-weight:400;letter-spacing:0.06em}
.order-header-jp{font-family:var(--ff-jp);font-size:10px;font-weight:200;color:rgba(240,232,213,0.3);letter-spacing:0.2em}
.order-close{width:36px;height:36px;border-radius:50%;background:rgba(240,232,213,0.06);border:none;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;color:rgba(240,232,213,0.6)}
.order-body{flex:1;overflow-y:auto;padding:16px 22px}
.order-item-row{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid rgba(240,232,213,0.05)}
.orow-emoji{font-size:28px;flex-shrink:0}
.orow-info{flex:1;min-width:0}
.orow-name{font-family:var(--ff-en);font-size:16px;font-weight:400}
.orow-jp{font-family:var(--ff-jp);font-size:9px;font-weight:200;color:rgba(240,232,213,0.28);letter-spacing:0.1em;margin-top:2px}
.orow-price{font-family:var(--ff-en);font-size:14px;color:var(--yama2);margin-top:3px}
.orow-qty{display:flex;align-items:center;gap:8px;flex-shrink:0}
.qty-b{width:28px;height:28px;border-radius:3px;border:1px solid rgba(240,232,213,0.12);background:rgba(240,232,213,0.05);color:var(--paper);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
.qty-b:active{background:rgba(122,46,30,0.3);transform:scale(0.88)}
.qty-n{font-size:15px;font-weight:400;min-width:22px;text-align:center}
.order-footer{padding:16px 22px calc(16px + env(safe-area-inset-bottom));border-top:1px solid rgba(240,232,213,0.06);flex-shrink:0}
.order-total-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px}
.order-total-label{font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,232,213,0.4)}
.order-total-val{font-family:var(--ff-en);font-size:28px;font-weight:400;color:var(--yama2)}
.place-btn{width:100%;padding:17px;border:none;border-radius:4px;background:linear-gradient(135deg,var(--beni3),var(--beni));font-family:var(--ff-ui);font-size:13px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--paper);cursor:pointer;box-shadow:0 6px 28px rgba(122,46,30,0.45);transition:all 0.2s}
.place-btn:active{transform:scale(0.98)}
.order-special{width:100%;padding:11px 14px;background:rgba(240,232,213,0.04);border:1px solid rgba(240,232,213,0.08);border-radius:4px;color:var(--paper);font-family:var(--ff-ui);font-size:11px;font-weight:300;resize:none;height:60px;line-height:1.5;margin-bottom:12px}
.order-special::placeholder{color:rgba(240,232,213,0.18)}
.order-special:focus{outline:none;border-color:rgba(240,232,213,0.15)}
.order-wa-note{display:flex;align-items:center;gap:10px;padding:10px 14px;background:rgba(37,200,100,0.05);border:1px solid rgba(37,200,100,0.14);border-radius:4px;margin-bottom:12px}
.wa-note-txt{font-size:10px;color:rgba(37,200,100,0.8)}
.wa-note-sub{font-size:9px;color:rgba(240,232,213,0.3)}

#successOverlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.9);display:none;flex-direction:column;align-items:center;justify-content:center;padding:32px;text-align:center}
#successOverlay.show{display:flex}
.success-icon{font-size:60px;margin-bottom:18px;animation:popIn 0.5s cubic-bezier(0.34,1.56,0.64,1)}
@keyframes popIn{0%{transform:scale(0.3);opacity:0}100%{transform:scale(1);opacity:1}}
.success-title{font-family:var(--ff-en);font-size:30px;font-weight:400;margin-bottom:4px}
.success-jp{font-family:var(--ff-jp);font-size:12px;font-weight:200;color:rgba(240,232,213,0.35);letter-spacing:0.3em;margin-bottom:20px}
.success-kot{width:100%;max-width:300px;background:rgba(240,232,213,0.04);border:1px solid rgba(240,232,213,0.08);border-radius:6px;padding:14px;text-align:left;margin-bottom:22px}
.kot-header{font-size:8px;letter-spacing:0.22em;text-transform:uppercase;color:rgba(37,200,100,0.65);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.kot-dot{width:5px;height:5px;border-radius:50%;background:rgba(37,200,100,0.7)}
.kot-body{font-family:monospace;font-size:10px;color:rgba(240,232,213,0.45);line-height:1.8;white-space:pre-wrap}
.success-done{padding:14px 36px;background:var(--beni);border:none;border-radius:4px;font-family:var(--ff-ui);font-size:13px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--paper);cursor:pointer}

#toast{position:fixed;top:-60px;left:50%;transform:translateX(-50%);z-index:500;background:rgba(20,60,25,0.92);border:1px solid rgba(37,200,100,0.2);border-radius:3px;padding:9px 18px;font-size:12px;font-weight:500;color:#8DC89A;white-space:nowrap;transition:top 0.4s cubic-bezier(0.34,1.56,0.64,1);pointer-events:none;letter-spacing:0.05em}
#toast.show{top:calc(14px + env(safe-area-inset-top))}
.global-loader{position:fixed;inset:0;z-index:8000;background:var(--ink);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:14px;transition:opacity 0.6s ease}
.global-loader.hide{opacity:0;pointer-events:none}
.gl-ring{width:28px;height:28px;border:1.5px solid rgba(122,46,30,0.15);border-top-color:var(--beni2);border-radius:50%;animation:spin 0.7s linear infinite}
.gl-txt{font-size:9px;letter-spacing:0.28em;text-transform:uppercase;color:rgba(240,232,213,0.22)}
</style>
</head>
<body>

<div class="global-loader" id="globalLoader"><div class="gl-ring"></div><div class="gl-txt">読込中 · Loading</div></div>

<div id="splash">
  <div class="splash-mon">
    <svg width="50" height="50" viewBox="0 0 64 64" fill="none">
      <circle cx="32" cy="32" r="29" stroke="rgba(122,46,30,0.45)" stroke-width="1"/>
