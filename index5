/* ════════════════════════════════
   RAF LOOP
════════════════════════════════ */
function startRafLoop() {
  function loop() {
    const diff = targetY - scrollY;
    scrollY += sliderDragging ? diff : diff * 0.1;
    if (Math.abs(diff) < 0.15) scrollY = targetY;
    scrollY = Math.max(0, Math.min(totalScrollH, scrollY));
    document.getElementById('cardTrack').style.transform = `translateY(${-scrollY}px)`;
    syncSliderVisual();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}

/* ════════════════════════════════
   SLIDER — pointer events on #sliderPanel ONLY
   Uses setPointerCapture so the drag is fully owned
   by the slider panel and never leaks to model-viewer
════════════════════════════════ */
function initSliderDrag() {
  const wrap    = document.getElementById('sliderTrackWrap');
  const tooltip = document.getElementById('sliderTooltip');

  function progressFromClientY(clientY) {
    const r = wrap.getBoundingClientRect();
    return Math.max(0, Math.min(1, (clientY - r.top) / r.height));
  }
  function applyProgress(p) {
    targetY = p * totalScrollH;
    const idx  = Math.min(menuItems.length - 1, Math.round(p * (menuItems.length - 1)));
    const item = menuItems[idx];
    tooltip.textContent = (idx + 1) + ' · ' + (item ? item.name : '');
    tooltip.classList.add('show');
    clearTimeout(tooltipTimer);
  }
  function endDrag() {
    sliderDragging = false;
    document.getElementById('sliderThumb').classList.remove('active');
    tooltipTimer = setTimeout(() => tooltip.classList.remove('show'), 900);
  }

  // Pointer events: captures the pointer so ALL subsequent moves are
  // delivered to #sliderTrackWrap even if the finger moves outside it.
  // This is completely separate from the model-viewer's touch handling.
  wrap.addEventListener('pointerdown', e => {
    sliderDragging = true;
    wrap.setPointerCapture(e.pointerId);   // claim this pointer exclusively
    document.getElementById('sliderThumb').classList.add('active');
    applyProgress(progressFromClientY(e.clientY));
    e.preventDefault();
    e.stopPropagation();                   // don't let it reach scrollArea
  });
  wrap.addEventListener('pointermove', e => {
    if (!sliderDragging) return;
    applyProgress(progressFromClientY(e.clientY));
    e.preventDefault();
    e.stopPropagation();
  });
  wrap.addEventListener('pointerup',     endDrag);
  wrap.addEventListener('pointercancel', endDrag);
}

function syncSliderVisual() {
  const p     = totalScrollH > 0 ? scrollY / totalScrollH : 0;
  const wrap  = document.getElementById('sliderTrackWrap');
  const thumb = document.getElementById('sliderThumb');
  const fill  = document.getElementById('sliderFill');
  if (!wrap || !thumb) return;
  const wh     = wrap.clientHeight;
  const th     = thumb.clientHeight || 30;
  const usable = wh - th;
  const top    = Math.max(0, Math.min(usable, p * usable));
  thumb.style.top     = top + 'px';
  fill.style.height   = (top + th / 2) + 'px';
}

/* ════════════════════════════════
   SCROLL AREA — touch/wheel/keyboard
   These only fire when the touch STARTS in #scrollArea,
   so model-viewer's internal touch handling runs first
   for touches that start on the model.
   
   Key insight: model-viewer calls e.stopPropagation()
   internally, so swipe-to-scroll only works when the
   user starts their touch on the non-model parts
   (info panel, actions bar).
════════════════════════════════ */
function initScrollArea() {
  const area = document.getElementById('scrollArea');

  // ── TOUCH SWIPE (only on non-model areas) ──
  let touchStartY = 0, touchTargetY0 = 0, velY = 0, lastTY = 0, lastTTime = 0;
  let flingId = null;
  let touchOnModel = false;

  area.addEventListener('touchstart', e => {
    // Check if the touch started on a model-viewer element
    touchOnModel = !!e.target.closest('model-viewer');
    if (touchOnModel) return;  // model-viewer will handle it

    cancelAnimationFrame(flingId);
    touchStartY  = e.touches[0].clientY;
    touchTargetY0 = targetY;
    velY = 0; lastTY = touchStartY; lastTTime = Date.now();
  }, { passive: true });

  area.addEventListener('touchmove', e => {
    if (touchOnModel) return;  // let model-viewer handle rotation
    const now = Date.now(), cy = e.touches[0].clientY;
    velY = (lastTY - cy) / ((now - lastTTime) || 1);
    lastTY = cy; lastTTime = now;
    targetY = Math.max(0, Math.min(totalScrollH, touchTargetY0 + (touchStartY - cy)));
  }, { passive: true });

  area.addEventListener('touchend', () => {
    if (touchOnModel) { touchOnModel = false; return; }
    let v = velY * 16;
    function fling() {
      if (Math.abs(v) < 0.3) return;
      targetY = Math.max(0, Math.min(totalScrollH, targetY + v));
      v *= 0.9;
      flingId = requestAnimationFrame(fling);
    }
    flingId = requestAnimationFrame(fling);
  }, { passive: true });

  // ── WHEEL ──
  area.addEventListener('wheel', e => {
    e.preventDefault();
    targetY = Math.max(0, Math.min(totalScrollH, targetY + e.deltaY * 1.1));
  }, { passive: false });

  // ── KEYBOARD ──
  document.addEventListener('keydown', e => {
    const s = viewH * 0.75;
    if (e.key === 'ArrowDown') targetY = Math.min(totalScrollH, targetY + s);
    if (e.key === 'ArrowUp')   targetY = Math.max(0, targetY - s);
  });
}

/* ════════════════════════════════
