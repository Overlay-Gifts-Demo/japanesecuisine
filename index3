        <!-- Corners -->
        <div class="viewer-corner tl"></div>
        <div class="viewer-corner tr"></div>
        <div class="viewer-corner bl"></div>
        <div class="viewer-corner br"></div>
        <!-- Badge -->
        <div class="viewer-badge">
          <div class="vb-dot"></div>
          <div class="vb-txt">${has3d ? '3D · ドラッグで回転' : '料理プレビュー'}</div>
        </div>
        ${idx===0 ? `
          <div class="swipe-indicator">
            <div class="swipe-arrow">↑</div>
            <div class="swipe-txt">Swipe for next dish</div>
          </div>
        ` : ''}
      </div>

      <!-- SUMI DIVIDER -->
      <div class="sumi-line">
