            exposure="1.1" environment-image="neutral"
            camera-controls interaction-prompt="none"
            min-camera-orbit="auto auto 5%"
            max-camera-orbit="auto auto 200%"
            xr-environment
            style="width:100%;height:100%;background:transparent;--poster-color:transparent;">
          </model-viewer>
          <div class="model-loader" id="loader_${idx}">
            <div class="loader-ring"></div>
            <div class="loader-txt">読込中…</div>
          </div>
        ` : `
          <div class="viewer-no-model">
            <div class="viewer-no-emoji">${item.emoji}</div>
            <div class="viewer-no-txt">3D Preview Coming Soon</div>
          </div>
