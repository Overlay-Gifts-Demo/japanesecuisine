          <path d="M10 5 Q80 1 160 4 Q240 7 310 3" stroke="rgba(122,46,30,0.45)" stroke-width="2" stroke-linecap="round"/>
          <path d="M10 6 Q80 3 160 5 Q240 8 310 5" stroke="rgba(122,46,30,0.12)" stroke-width="0.8" stroke-linecap="round"/>
