/* ─── FETCH MENU ─── */
async function fetchMenu() {
  try {
    const res  = await fetch(SHEET_URL);
    const text = await res.text();
    const m    = text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
    if (!m) throw new Error('bad');
    const json = JSON.parse(m[1]);
    const cols = json.table.cols.map(c => c.label.toLowerCase().trim());
    const get  = (row,col) => { const i=cols.indexOf(col); return (i>=0&&row.c[i]&&row.c[i].v!=null)?String(row.c[i].v).trim():''; };
    menuItems = json.table.rows.filter(r=>r&&r.c).map((r,i)=>({
      id:         get(r,'id')||'i'+i,
      name:       get(r,'name'),
      jp:         get(r,'jp_name'),
      category:   get(r,'category'),
      description:get(r,'description'),
      price:      parseInt(get(r,'price'))||0,
      emoji:      get(r,'emoji')||'🍽️',
      veg:        get(r,'veg').toLowerCase()==='yes',
      chef_pick:  get(r,'chef_pick').toLowerCase()==='yes',
      new:        get(r,'new').toLowerCase()==='yes',
      available:  get(r,'available').toLowerCase()!=='no',
      glb_url:    get(r,'glb_url'),
    })).filter(i=>i.name);
  } catch(e) {
    menuItems = FALLBACK;
  }
  buildReels();
}

/* ─── BUILD REELS ─── */
