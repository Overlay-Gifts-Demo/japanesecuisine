/* ─── SIDE SLIDER ─── */
function stopSlideProp(e) {
  e.stopPropagation();
}

function updateSideSliderTrack(slider, val, max) {
  /* vertical slider: thumb at top = idx 0, bottom = last.
     Because we rotated 180deg, value 0 = top visually.
     Fill percentage from top: val/max * 100 */
  const pct = max > 0 ? (val / max * 100).toFixed(1) : 0;
  /* We update the gradient from bottom since writing-mode + rotate maps differently.
     Keep it simple: use a CSS var on the element */
  slider.style.background = `linear-gradient(to top, var(--beni2) 0%, var(--beni2) ${pct}%, rgba(240,232,213,0.1) ${pct}%, rgba(240,232,213,0.1) 100%)`;
}

function onSideSliderInput(slider) {
  const idx = parseInt(slider.value);
  const max = menuItems.length - 1;
  updateSideSliderTrack(slider, idx, max);
  document.getElementById('sideSliderIdx').textContent = idx + 1;
  scrollToCard(idx);
}

/* ─── TOUCH / SCROLL NAVIGATION ─── */
let startY = 0, startX = 0, isDragging = false;

function getCardH() { return window.innerHeight; }

function scrollToCard(idx) {
  const total = menuItems.length;
  idx = Math.max(0, Math.min(total - 1, idx));
  currentIdx = idx;
  const track = document.getElementById('reelTrack');
  track.style.transform = `translateY(${-idx * getCardH()}px)`;

  /* Sync side slider */
  const sl = document.getElementById('sideSlider');
  sl.value = idx;
  updateSideSliderTrack(sl, idx, total - 1);
  document.getElementById('sideSliderIdx').textContent = idx + 1;
}

function setupTouch() {
  const wrap = document.getElementById('reelWrap');

  wrap.addEventListener('touchstart', e => {
    if(e.target.id === 'sideSlider') return;
    startY = e.touches[0].clientY;
    startX = e.touches[0].clientX;
    isDragging = true;
  }, {passive:true});

  wrap.addEventListener('touchend', e => {
    if(!isDragging) return;
    isDragging = false;
    const dy = startY - e.changedTouches[0].clientY;
    const dx = Math.abs(startX - e.changedTouches[0].clientX);
    if(Math.abs(dy) > 50 && Math.abs(dy) > dx * 1.5) {
      scrollToCard(currentIdx + (dy > 0 ? 1 : -1));
    }
  }, {passive:true});

  document.addEventListener('keydown', e => {
    if(e.key==='ArrowDown') scrollToCard(currentIdx+1);
    if(e.key==='ArrowUp')   scrollToCard(currentIdx-1);
  });
}

/* ─── AR TRIGGER ─── */
function triggerAR(idx) {
  const mv = document.getElementById('mv_' + idx);
  if(mv) mv.activateAR();
}

/* ─── CART ─── */
function addToCart(id, cardIdx) {
  const item = menuItems.find(i=>i.id===id);
  if(!item || !item.available) return;
  cart[id] = (cart[id]||0) + 1;
  updateCartUI();

  const btn = document.getElementById('addCartBtn_' + cardIdx);
  if(btn) {
    btn.classList.add('added-pulse');
    setTimeout(() => btn.classList.remove('added-pulse'), 700);
  }

  const counter = document.getElementById('cartCounter_' + cardIdx);
  if(counter) {
    counter.textContent = cart[id];
    counter.classList.add('show');
  }

  showToast(item.emoji + ' ' + item.name + ' added');
}

function updateCartUI() {
  const count = Object.values(cart).reduce((a,b)=>a+b,0);
  const el = document.getElementById('hudCartCount');
  el.textContent = count;
  el.classList.toggle('show', count>0);
}

/* ─── ORDER SCREEN ─── */
function openOrder() {
  const body = document.getElementById('orderBody');
  body.innerHTML = '';
  let total = 0;
  const entries = Object.entries(cart).filter(([,q])=>q>0);
  if(!entries.length) {
    body.innerHTML = '<div style="text-align:center;padding:40px 20px;color:rgba(240,232,213,0.3);font-family:var(--ff-en);font-size:18px;font-style:italic;">Your order is empty<br><small style=\'font-size:12px;font-family:var(--ff-jp);font-weight:200;\'>まだ注文がありません</small></div>';
  } else {
    entries.forEach(([id,qty]) => {
      const item = menuItems.find(i=>i.id===id);
      if(!item) return;
      const sub = item.price * qty; total += sub;
      const row = document.createElement('div');
      row.className = 'order-item-row';
      row.innerHTML = `
        <div class="orow-emoji">${item.emoji}</div>
        <div class="orow-info">
          <div class="orow-name">${item.name}</div>
          <div class="orow-jp">${item.jp||''}</div>
          <div class="orow-price">₹ ${sub.toLocaleString('en-IN')}</div>
        </div>
        <div class="orow-qty">
          <button class="qty-b" onclick="changeCartQty('${id}')">−</button>
          <div class="qty-n">${qty}</div>
          <button class="qty-b" onclick="addToCartDirect('${id}')">+</button>
        </div>`;
      body.appendChild(row);
    });
  }
  document.getElementById('orderTotal').textContent = '₹ ' + total.toLocaleString('en-IN');
  document.getElementById('screenOrder').classList.add('show');
}

function closeOrder() {
  document.getElementById('screenOrder').classList.remove('show');
}

function changeCartQty(id) {
  if(!cart[id]) return;
  cart[id]--;
  if(cart[id]<=0) delete cart[id];
  updateCartUI();
  syncCardQtyBadges();
  openOrder();
}

function addToCartDirect(id) {
  cart[id] = (cart[id]||0)+1;
  updateCartUI();
  syncCardQtyBadges();
  openOrder();
}

function syncCardQtyBadges() {
  menuItems.forEach((item,idx) => {
    const counter = document.getElementById('cartCounter_'+idx);
    if(!counter) return;
    const q = cart[item.id]||0;
    counter.textContent = q;
    counter.classList.toggle('show', q>0);
  });
}

/* ─── PLACE ORDER ─── */
function placeOrder() {
  const entries = Object.entries(cart).filter(([,q])=>q>0);
  if(!entries.length) return;
  const note = document.getElementById('specialNote').value.trim();
  let total = 0;
  const snap = [];
  entries.forEach(([id,qty]) => {
    const item = menuItems.find(i=>i.id===id);
    if(!item) return;
    snap.push({item,qty});
    total += item.price * qty;
  });
  const orderId = '#ORD-' + Math.floor(1000+Math.random()*9000);
  const now  = new Date();
  const time = now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
  const date = now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  let lines = '';
  snap.forEach(({item,qty}) => {
    lines += item.name.padEnd(18)+' ×'+qty+'  ₹'+(item.price*qty).toLocaleString('en-IN')+'\n';
  });
  const msg = `🍽️ *NEW ORDER — KOT*\n━━━━━━━━━━━━━━━━━━━━\n*Table  :* ${TABLE_NUMBER}\n*Seat   :* ${TABLE_INFO}\n*Order  :* ${orderId}\n*Time   :* ${time}, ${date}\n━━━━━━━━━━━━━━━━━━━━\n${lines}━━━━━━━━━━━━━━━━━━━━\n*TOTAL  :* ₹${total.toLocaleString('en-IN')}\n━━━━━━━━━━━━━━━━━━━━${note?'\n📝 *Note:* '+note:''}\n_Sent via Sakura AR Menu · さくら_`;

  let preview = '';
  snap.forEach(({item,qty}) => { preview += item.name+' × '+qty+'  ₹'+(item.price*qty).toLocaleString('en-IN')+'\n'; });
  preview += '\n合計: ₹'+total.toLocaleString('en-IN');
  if(note) preview += '\n📝 '+note;
  document.getElementById('kotBody').textContent = preview;

  closeOrder();
  document.getElementById('successOverlay').classList.add('show');
  setTimeout(()=>window.open('https://wa.me/'+KITCHEN_WA+'?text='+encodeURIComponent(msg),'_blank'),500);

  Object.keys(cart).forEach(k=>delete cart[k]);
  document.getElementById('specialNote').value='';
  updateCartUI();
  syncCardQtyBadges();
}

function closeSuccess() {
  document.getElementById('successOverlay').classList.remove('show');
}

/* ─── TOAST ─── */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = '✓ ' + msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2600);
}

/* ─── INIT ─── */
async function init() {
  await fetchMenu();
  setTimeout(() => {
    document.getElementById('splash').classList.add('out');
    setTimeout(()=>{ document.getElementById('splash').style.display='none'; }, 1000);
  }, 4000);
}

init();
document.addEventListener('contextmenu', e=>e.preventDefault());
</script>
</body>
</html>
